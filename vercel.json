{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/calendar.ics", "destination": "/calendar.ics" },
    { "source": "/calendar-2025.ics", "destination": "/calendar-2025.ics" },
    { "source": "/calendar-2027.ics", "destination": "/calendar-2027.ics" }
  ]
}
